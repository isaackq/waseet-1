<div style="max-width: 600px; margin: 0 auto; padding: 24px; font-family: Arial, sans-serif; color: #1f2937; background: #f8fafc;">
  <div style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 32px;">
    <h2 style="margin: 0 0 16px; color: #111827;">Reset your password</h2>
    <p style="margin: 0 0 16px;">Hello <%= name %>,</p>
    <p style="margin: 0 0 20px;">
      We received a request to reset your password. Click the button below to set a new password.
    </p>
    <p style="margin: 0 0 24px;">
      <a
        href="<%= resetUrl %>"
        style="display: inline-block; background: #111827; color: #ffffff; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: 600;"
      >
        Reset Password
      </a>
    </p>
    <p style="margin: 0 0 12px; color: #4b5563;">
      If the button does not work, use this link:
    </p>
    <p style="margin: 0 0 20px; word-break: break-all;">
      <a href="<%= resetUrl %>" style="color: #2563eb;"><%= resetUrl %></a>
    </p>
    <p style="margin: 0; color: #6b7280; font-size: 14px;">
      This link expires soon. If you did not request a password reset, you can ignore this email.
    </p>
  </div>
</div>
