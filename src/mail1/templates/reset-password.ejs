<div style="margin:0;padding:32px 16px;background:#f8fafc;font-family:Arial,sans-serif;color:#0f172a;">
  <div style="max-width:640px;margin:0 auto;background:#ffffff;border:1px solid #e2e8f0;border-radius:18px;overflow:hidden;box-shadow:0 18px 60px rgba(15,23,42,0.10);">
    <div style="padding:26px 28px;background:linear-gradient(135deg,#08729f 0%,#0a5f86 100%);color:#ffffff;">
      <div style="font-size:12px;letter-spacing:1.6px;text-transform:uppercase;opacity:0.92;font-weight:800;">Waseet</div>
      <h1 style="margin:10px 0 0;font-size:24px;line-height:1.25;">Reset your password</h1>
      <p style="margin:10px 0 0;font-size:13px;line-height:1.6;opacity:0.95;">
        Use the secure link below to reset your Waseet account password.
      </p>
    </div>

    <div style="padding:28px;">
      <p style="margin:0 0 14px;font-size:15px;line-height:1.7;color:#0f172a;">
        Hi <strong><%= name %></strong>,
      </p>

      <p style="margin:0 0 18px;font-size:15px;line-height:1.7;color:#334155;">
        We received a request to reset your password. Click the button below to continue.
      </p>

      <div style="margin:0 0 18px;">
        <a
          href="<%= resetUrl %>"
          style="display:inline-block;padding:14px 22px;background:#08729f;color:#ffffff;text-decoration:none;border-radius:12px;font-weight:800;box-shadow:0 14px 30px rgba(8,114,159,0.18);"
        >
          Reset Password
        </a>
      </div>

      <div style="padding:14px 16px;border:1px solid #e2e8f0;background:#f8fafc;border-radius:14px;">
        <p style="margin:0;font-size:13px;line-height:1.7;color:#475569;">
          If the button does not work, copy and paste this link into your browser:
        </p>
        <p style="margin:10px 0 0;font-size:13px;line-height:1.7;word-break:break-all;">
          <a href="<%= resetUrl %>" style="color:#08729f;text-decoration:none;"><%= resetUrl %></a>
        </p>
      </div>

      <p style="margin:18px 0 0;font-size:13px;line-height:1.7;color:#475569;">
        If you didn&#39;t request this, you can safely ignore this email.
      </p>

      <p style="margin:18px 0 0;font-size:12px;line-height:1.7;color:#64748b;">
        &copy; Waseet
      </p>
    </div>
  </div>
</div>
